🔹 PRACTICAL 4B – Parameterized + Scheduled Pipeline
pipeline {
    agent any

    parameters {
        string(name: 'USERNAME', defaultValue: 'Student', description: 'Enter your name')
    }

    triggers {
        cron('H/2 * * * *') // runs every 2 minutes
    }

    stages {

        stage('Greeting') {
            steps {
                echo "Hello, ${params.USERNAME}!"
                bat "echo Hello ${params.USERNAME}! This is your scheduled Jenkins job! > message.txt"
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'message.txt'
            }
        }
    }

    post {
        success {
            echo "Build completed successfully!"
        }
    }
}
🔹 PRACTICAL 5A – Maven Build Pipeline (IMPORTANT)
pipeline {
    agent any

    tools {
        maven 'Maven'   // Make sure Maven is configured in Jenkins
    }

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/your-repo/maven-project.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Package') {
            steps {
                bat 'mvn package'
            }
        }
    }

    post {
        success {
            echo 'Maven build successful!'
        }
        failure {
            echo 'Build failed!'
        }
    }
}
