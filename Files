## 🔹 PRACTICAL 4B – Parameterized + Scheduled Pipeline

```groovy
pipeline {
    agent any

    parameters {
        string(name: 'USERNAME', defaultValue: 'Student', description: 'Enter your name')
    }

    triggers {
        cron('H/2 * * * *') // runs every 2 minutes
    }

    stages {

        stage('Greeting') {
            steps {
                echo "Hello, ${params.USERNAME}!"
                bat "echo Hello ${params.USERNAME}! This is your scheduled Jenkins job! > message.txt"
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'message.txt'
            }
        }
    }

    post {
        success {
            echo "Build completed successfully!"
        }
    }
}
```

